      <aliases enabled='yes' />
      <column caption='Churn Rate (%)' datatype='integer' name='[Calculation_3218007196639232]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [churned] = &quot;YES&quot; THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Age Highlight' datatype='string' name='[Calculation_3218007205294081]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age_band] = &quot;18-24&quot;&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Tenure Highlight' datatype='string' name='[Calculation_3218007206907906]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure_band] IN (&quot;New (0)&quot;, &quot;1-12m&quot;)&#10;THEN &quot;First Year&quot;&#10;ELSE &quot;Established Customer&quot;&#10;END' />
      </column>
      <column caption='Product Highlight' datatype='string' name='[Calculation_3218007210696707]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [number_of_products]= 1&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Mobile Highlight' datatype='string' name='[Calculation_3218007221075975]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [engagement_band] = &apos;Very Low&apos;&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Complaint Highlight' datatype='string' name='[Calculation_3218007388229640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [complaint_band]= &apos;3+&apos;&#10;THEN &quot;Highlight&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
