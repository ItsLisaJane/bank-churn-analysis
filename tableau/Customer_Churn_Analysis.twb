  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Customer Churn Analysis'>
      <style />
      <size maxheight='900' maxwidth='1600' minheight='900' minwidth='1600' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='17' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='100000' id='23' param='horz' type-v2='layout-flow' w='100000' x='0' y='0'>
            <zone h='100000' id='20' param='horz' type-v2='layout-flow' w='100000' x='0' y='0'>
              <zone h='100000' id='18' type-v2='layout-basic' w='100000' x='0' y='0' />
            </zone>
          </zone>
        </zone>
        <zone h='29000' id='9' name='New Customers' w='27625' x='36375' y='11444'>
          <layout-cache cell-count-w='5' minheight='184' non-cell-size-w='71' type-h='scalable' type-w='cell' />
        </zone>
        <zone h='33222' id='5' name='Age Band' w='30563' x='4000' y='11444'>
          <layout-cache fixed-size-h='292' minwidth='180' type-h='fixed' type-w='scalable' />
        </zone>
        <zone h='20333' id='13' name='Complaints' w='30500' x='3938' y='43000' />
        <zone h='33889' id='16' name='Mobile' w='93250' x='3875' y='65556' />
        <zone h='26111' id='21' name='Product Count' w='59875' x='36375' y='43000' />
        <zone forceUpdate='true' h='4889' id='24' type-v2='text' w='20125' x='40125' y='1222'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Avenir' fontsize='20'>Customer Churn Analysis</run>
          </formatted-text>
        </zone>
        <zone h='5778' id='25' type-v2='text' w='33125' x='33375' y='4778'>
          <formatted-text>
            <run fontname='Avenir' fontsize='12'>Analysis of customer retention drivers across a UK retail banking portfolio</run>
          </formatted-text>
        </zone>
        <zone forceUpdate='true' h='28889' id='27' type-v2='text' w='31688' x='66250' y='11333'>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Avenir' fontsize='12'>Key Findings</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Customers aged 18–24 exhibit the highest churn rates.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• New customers are twice as likely to leave as long-tenured customers.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Low-engagement customers are 6x more likely to churn.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Single-product customers are at elevated churn risk.</run>
            <run>Æ&#10;&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Avenir' fontsize='12'>Recommendations</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Improve onboarding for new customers.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Increase mobile engagement through incentives and personalised communications.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Prioritise complaint resolution and service recovery.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Avenir' fontsize='10'>• Expand product penetration through targeted cross-selling.</run>
          </formatted-text>
        </zone>
      </zones>
      <devicelayouts>
        <devicelayout auto-generated='true' name='Phone'>
          <size maxheight='1500' minheight='1500' sizing-mode='vscroll' />
          <zones>
            <zone h='100000' id='29' type-v2='layout-basic' w='100000' x='0' y='0'>
